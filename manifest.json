{
  "manifest_version": 3,
  "name": "Libro.fm ALC Checker",
  "version": "1.0",
  "description": "Lets you know if you already own an audiobook on the monthly ALC list, and adds genre information to each book on the ALC list.",
  "permissions": [
    "tabs"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open Libro.fm"
  },

  "content_scripts": [
    {
      "matches": ["*://*.libro.fm/playlists/alc*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}