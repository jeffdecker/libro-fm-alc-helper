{
  "manifest_version": 3,
  "name": "Libro.fm ALC Helper",
  "version": "1.0.1",
  "description": "See which ALC audiobooks you already own, complete with color-coded genre tags.",
  "permissions": [
    "tabs",
    "storage"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open Options"
  },

  "options_page": "options.html",

  "content_scripts": [
    {
      "matches": ["*://*.libro.fm/playlists/alc*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}